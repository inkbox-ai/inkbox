{
  "name": "@inkbox/sdk",
  "version": "0.4.26",
  "description": "TypeScript SDK for the Inkbox API",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tunnels/connect": {
      "types": "./dist/tunnels/client/index.d.ts",
      "node": "./dist/tunnels/client/index.js"
    }
  },
  "files": [
    "dist",
    "protocol",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "verify:bundle": "node scripts/verify-bundle.mjs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@peculiar/x509": "^2.0.0",
    "hash-wasm": "^4.11.0",
    "reflect-metadata": "^0.2.2",
    "undici": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/inkbox-ai/inkbox",
    "directory": "sdk/typescript"
  },
  "homepage": "https://inkbox.ai",
  "bugs": {
    "url": "https://github.com/inkbox-ai/inkbox/issues"
  },
  "engines": {
    "node": ">=22"
  }
}
